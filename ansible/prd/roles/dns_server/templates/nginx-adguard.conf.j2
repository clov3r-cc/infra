server {
    listen 8443 ssl;
    http2 on;
    server_name _;

    ssl_certificate     /etc/lego/certificates/{{ nginx_cert_domain }}.crt;
    ssl_certificate_key /etc/lego/certificates/{{ nginx_cert_domain }}.key;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # nginx側とAdGuard Home側でHSTSが重複
    proxy_hide_header Strict-Transport-Security;

    # AdGuardが付与してくるAccess-Control-Allow-OriginがHTTPのままなので、HTTPSに修正
    proxy_hide_header Access-Control-Allow-Origin;
    add_header Access-Control-Allow-Origin "https://{{ nginx_cert_domain }}" always;

    location / {
        # AdGuard側のHTTPS設定は、DoH設定と共通のため、HTTPに戻すことはできない
        proxy_pass https://{{ adguard_listen_addr }}:{{ adguard_https_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

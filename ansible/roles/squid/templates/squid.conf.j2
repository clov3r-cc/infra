# {{ ansible_managed }}
#
# Recommended minimum configuration:
#

{% for network in squid_allowed_networks %}
acl localnet src {{ network }}
{% endfor %}

acl SSL_ports port {{ squid_ssl_ports | join(' ') }}
{% for port in squid_safe_ports %}
acl Safe_ports port {{ port }}
{% endfor %}

#
# Recommended minimum Access Permission configuration:
#
http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports

http_access allow localhost manager
http_access deny manager

http_access allow localhost
http_access deny to_localhost
http_access deny to_linklocal

http_access allow localnet
http_access deny all

http_port {{ squid_http_port }}

cache_dir ufs {{ squid_cache_dir }} {{ squid_cache_size_mb }} 16 256
cache_mem {{ squid_cache_mem_mb }} MB
maximum_object_size {{ squid_max_object_size_mb }} MB

coredump_dir {{ squid_cache_dir }}

dns_v4_first on

refresh_pattern ^ftp:           1440    20%     10080
refresh_pattern -i (/cgi-bin/|\?) 0     0%      0
refresh_pattern .               0       20%     4320
